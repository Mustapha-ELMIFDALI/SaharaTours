# ============================================================
#  SaharaTours — .gitignore
#  Stack : Spring Boot (Maven) + React / Vite + Docker
# ============================================================

# ── Java / Spring Boot ───────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

.mvn/wrapper/maven-wrapper.properties

# Spring Boot dev tools restart file
.spring-boot-devtools.properties
spring-shell.log

# ── Maven ────────────────────────────────────────────────────
.mvn/timing.properties
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties

# ── Node / npm / React ───────────────────────────────────────
node_modules/
dist/
build/
.vite/
*.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Environment & secrets ────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.test
.env*.local

# application secrets (never commit real credentials)
src/main/resources/application-prod.yml
src/main/resources/application-prod.properties
src/main/resources/secrets.yml

# ── IDEs ─────────────────────────────────────────────────────

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/
.idea_modules/

# VS Code
.vscode/
!.vscode/extensions.json

# Eclipse
.classpath
.project
.settings/
bin/

# NetBeans
nbproject/private/
nbbuild/
nbdist/
nbactions.xml
nb-configuration.xml

# ── OS ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Docker ───────────────────────────────────────────────────
# keep docker-compose.yml but ignore override files with secrets
docker-compose.override.yml
docker-compose.prod.yml

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── Testing ──────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
surefire-reports/

# ── Claude ───────────────────────────────────────────────────
.claude/

# ── Scripts ──────────────────────────────────────────────────
SaharaTours.ps1
build_history.sh

# ── Misc ─────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
*~
.cache/
